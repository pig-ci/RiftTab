{
  "manifest_version": 3,
  "name": "Rift Tab",
  "short_name": "Rift Tab",
  "version": "1.0",
  "description": "極簡專注的新分頁計時與白噪音空間。",
  "start_url": "./index.html",
  "display": "standalone",
  "background_color": "#000000",
  "theme_color": "#000000",
  "icons": [
    {
      "src": "favicon.svg",
      "sizes": "any",
      "type": "image/svg+xml"
    }
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  }
}